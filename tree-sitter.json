{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "clips",
      "camelcase": "Clips",
      "title": "Clips",
      "scope": "source.clips",
      "file-types": [
        "clips",
        "clp"
      ],
      "injection-regex": "^clips$",
      "class-name": "TreeSitterClips"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "tree-sitter grammar for CLIPS",
    "authors": [
      {
        "name": "Tarik Viehmann",
        "email": "viehmann@kbsg.rwth-aachen.de"
      }
    ],
    "links": {
      "repository": "https://github.com/TarikViehmann/treesitter-CLIPS"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}